# ============================================================
# Royal Results — environment variables
# Copy this file to `.env` and fill in real values.
# NEVER commit a populated `.env` (see .gitignore).
# ============================================================

# --- Runtime ------------------------------------------------
NODE_ENV=production
PORT=3000

# --- Database (MySQL via mysql2 + drizzle) ------------------
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=

# --- Stripe -------------------------------------------------
# Dashboard → Developers → API keys
STRIPE_SECRET_KEY=
# Dashboard → Developers → Webhooks → (endpoint) → Signing secret
STRIPE_WEBHOOK_SECRET=

# --- Auth / OAuth -------------------------------------------
JWT_SECRET=
OAUTH_SERVER_URL=
OWNER_OPEN_ID=

# --- Manus Forge (built-in AI gateway) ----------------------
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# --- Vite client-side (must be prefixed VITE_) --------------
VITE_APP_ID=
VITE_OAUTH_PORTAL_URL=
VITE_FRONTEND_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_URL=
