# esbuild is intentionally NOT in pnpm.onlyBuiltDependencies (see package.json),
# so its postinstall cannot execute a binary during `pnpm install`. This prevents
# EACCES errors on Hostinger's noexec build filesystem. esbuild 0.17+ ships its
# native binary via optional-dependency platform packages (@esbuild/linux-x64,
# etc.) which don't require a postinstall step to work.

# Use a flat node_modules layout for better compatibility with shared hosting
# environments that may not support pnpm's symlink-based virtual store layout.
node-linker=node-modules
